# =============================================================
# defect-pilot — environment configuration
# Copy this file to .env and fill in your values
# .env is gitignored — never commit real credentials
# =============================================================

# -----------------------------------------
# AI Provider
# Options: "anthropic" | "ollama"
# Use "ollama" for air-gapped / NDA environments
# -----------------------------------------
AI_PROVIDER=ollama

# -----------------------------------------
# Anthropic (used when AI_PROVIDER=anthropic)
# -----------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -----------------------------------------
# Ollama (used when AI_PROVIDER=ollama)
# Requires Ollama running locally: https://ollama.ai
# -----------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# -----------------------------------------
# Jira Cloud
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
# -----------------------------------------
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=PROJ

# -----------------------------------------
# Database (SQLite)
# Path to local defect tracking database
# -----------------------------------------
DB_PATH=./data/defects.db

# -----------------------------------------
# Logging
# Options: DEBUG | INFO | WARNING | ERROR
# -----------------------------------------
LOG_LEVEL=INFO
